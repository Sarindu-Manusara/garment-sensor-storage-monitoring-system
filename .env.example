MONGODB_URI=<your-mongodb-uri>
MONGODB_DATABASE=garment_monitoring
MONGODB_COLLECTION=sensor_readings
MONGODB_SENSOR_DATABASE=garment_monitoring
MONGODB_SENSOR_COLLECTION=sensor_readings
MONGODB_ML_COLLECTION=ml_predictions
MONGODB_CHAT_COLLECTION=chat_messages
MONGODB_ALERT_COLLECTION=alert_notifications
SERIAL_PORT=COM5
SERIAL_BAUD_RATE=9600
SERIAL_DELIMITER=\r\n
DEVICE_ID=esp32-garment-1
API_PORT=3001
PYTHON_BIN=py
ZONE=zone1
PUBLIC_DASHBOARD_URL=<your-public-dashboard-url>
LIVE_ML_MONITOR_ENABLED=true
LIVE_ML_MONITOR_INTERVAL_MS=15000
TEMPERATURE_MEDIUM_THRESHOLD=28
TEMPERATURE_HIGH_THRESHOLD=30
HUMIDITY_MEDIUM_THRESHOLD=60
HUMIDITY_HIGH_THRESHOLD=70
LIGHT_MEDIUM_THRESHOLD=150
LIGHT_HIGH_THRESHOLD=300
DUST_MEDIUM_THRESHOLD=0.03
DUST_HIGH_THRESHOLD=0.045
GAS_MEDIUM_THRESHOLD=0.75
GAS_HIGH_THRESHOLD=1.5
MQ135_BASELINE_RAW=2800
BACKEND_MODEL_VERSION=backend-ml-v1
TINYML_MODEL_VERSION=tinyml-humidity-v1
CHAT_LLM_PROVIDER=openai
CHAT_LLM_API_KEY=<your-openai-api-key>
CHAT_LLM_BASE_URL=https://api.openai.com/v1
CHAT_LLM_MODEL=gpt-4.1-mini
CHAT_LLM_TIMEOUT_MS=15000
WAAPI_ENABLED=false
WAAPI_BASE_URL=https://waapi.app/api/v1/instances
WAAPI_INSTANCE_ID=<your-waapi-instance-id>
WAAPI_API_TOKEN=<your-waapi-api-token>
WAAPI_CHAT_IDS=<chat-id-1>,<chat-id-2>
WAAPI_RECIPIENT_PHONES=<recipient-phone-1>,<recipient-phone-2>
WAAPI_ALERT_COOLDOWN_MINUTES=30
WAAPI_SEND_WARNING_ALERTS=true
WAAPI_SEND_DANGER_ALERTS=true
VITE_API_BASE_URL=<your-public-backend-url>



